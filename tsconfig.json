{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",

    "lib": ["esnext"],

    "types": ["node"],

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "strict": true,

    "jsx": "react-jsx",

    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",

    "skipLibCheck": true
  },

  "include": [
    "src/**/*.ts",
    "src/types/**/*.d.ts"
, "src/test/helper/report.mts"  ],

  "exclude": [
    "node_modules",
    "reports",
    "allure-report",
    "allure-results"
  ]
}