  "main": "index.js",
  "scripts": {
    "test": "cross-env ENV=qa cucumber-js",
    "test:tamil": "cross-env ENV=qa cucumber-js --tags \"@Tamil\"",
    "test:mythily": "cross-env ENV=qa cucumber-js --tags \"@Mythily\"",
    "test:krishna": "cross-env ENV=qa cucumber-js --tags \"@krishna\"",
    "test:Subathra": "cross-env ENV=qa cucumber-js --tags \"@Subathra\"",
    "test:jerishwin": "cross-env ENV=qa cucumber-js --tags \"@Jerishwin\"",
    "test:rerun": "cross-env ENV=qa cucumber-js -p rerun",
    "posttest": "npx ts-node src/test/helper/report.mts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "debug": "cross-env ENV=qa PWDEBUG=1 cucumber-js"
  },
